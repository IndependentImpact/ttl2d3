# Simple example OWL ontology – 5 classes and 1 object property.
# Used as test input for the ttl2d3 Turtle parser.

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix ex:   <http://example.org/ontology#> .

<http://example.org/ontology>
    a owl:Ontology ;
    rdfs:label "Simple Example Ontology" ;
    owl:versionInfo "0.1.0" .

ex:Animal a owl:Class ;
    rdfs:label "Animal" .

ex:Vertebrate a owl:Class ;
    rdfs:label "Vertebrate" ;
    rdfs:subClassOf ex:Animal .

ex:Mammal a owl:Class ;
    rdfs:label "Mammal" ;
    rdfs:subClassOf ex:Vertebrate .

ex:Bird a owl:Class ;
    rdfs:label "Bird" ;
    rdfs:subClassOf ex:Vertebrate .

ex:Fish a owl:Class ;
    rdfs:label "Fish" ;
    rdfs:subClassOf ex:Vertebrate .

ex:hasParent a owl:ObjectProperty ;
    rdfs:label "has parent" ;
    rdfs:domain ex:Animal ;
    rdfs:range  ex:Animal .
